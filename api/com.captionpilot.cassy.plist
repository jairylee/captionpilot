<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.captionpilot.cassy</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/python3</string>
    <string>/Users/jairylee/.openclaw/workspace/scripts/cassy_approval_watcher.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/jairylee/.openclaw/workspace/scripts</string>

  <!-- Run every 5 minutes via StartInterval instead of looping -->
  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/Users/jairylee/.openclaw/workspace/logs/cassy-approval.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/jairylee/.openclaw/workspace/logs/cassy-approval.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/jairylee</string>
  </dict>
</dict>
</plist>
